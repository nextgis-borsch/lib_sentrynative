# Legacy NextGIS package (find_package(SENTYNATIVE)).
# Build tree: SENTYNATIVETargets.cmake with plain target "sentry".
# Install tree: includes sentry-targets.cmake (sentry::sentry) from lib/cmake/sentry.

if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/SENTYNATIVETargets.cmake")
	include("${CMAKE_CURRENT_LIST_DIR}/SENTYNATIVETargets.cmake")
	set(_sentry_legacy_tgt sentry)
else()
	get_filename_component(_sentrynative_prefix "${CMAKE_CURRENT_LIST_DIR}/../../../" ABSOLUTE)
	set(_sentry_targets "${_sentrynative_prefix}/@CMAKE_INSTALL_LIBDIR@/cmake/sentry/sentry-targets.cmake")
	if(NOT EXISTS "${_sentry_targets}")
		message(FATAL_ERROR "SENTYNATIVE: missing \"${_sentry_targets}\" (install Sentry-Native CMake package).")
	endif()
	include("${_sentry_targets}")
	set(_sentry_legacy_tgt sentry::sentry)
endif()

if(NOT TARGET ${_sentry_legacy_tgt})
	message(FATAL_ERROR "SENTYNATIVE: sentry target not defined after loading exports.")
endif()

get_property(SENTYNATIVE_INCLUDE_DIRS TARGET ${_sentry_legacy_tgt} PROPERTY INTERFACE_INCLUDE_DIRECTORIES)
set(SENTYNATIVE_LIBRARIES "${_sentry_legacy_tgt}")
set(SENTYNATIVE_VERSION "@SENTRY_VERSION_BASE@")
set(SENTYNATIVE_FOUND TRUE)
